<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Portal Content List</masterLabel>
    <description>Displays published alumni portal content from Salesforce-managed records. Data wiring is added after object contracts are finalized.</description>
    <targets>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightningCommunity__Default">
            <property name="heading" type="String" label="Heading" default="Featured for you"/>
            <property name="kicker" type="String" label="Kicker" default="Alumni and friends"/>
            <property name="emptyStateMessage" type="String" label="Empty State Message" default="No featured content is available right now."/>
            <property name="useSampleData" type="Boolean" label="Show Sample Data" default="false"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>

